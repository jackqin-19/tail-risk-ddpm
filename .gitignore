# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.egg-link

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (raw and processed data should not be committed unless small)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Outputs (large or generated files should not be committed)
outputs/checkpoints/*
outputs/samples/*
outputs/figures/*
outputs/tables/*
outputs/logs/*
!outputs/checkpoints/.gitkeep
!outputs/samples/.gitkeep
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/logs/.gitkeep

# Logs / experiment tracking
wandb/
*.tfevents.*
*.log
*.txt

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage / testing
.coverage
htmlcov/
.pytest_cache/
